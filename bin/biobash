#!/bin/bash
# -----------------------------------------------------------------------------
# BioBash: A Bioinformatics Suite for BAHS Scripts
# -----------------------------------------------------------------------------

set -e

# Base directory
BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BASE_DIR="$(dirname "$BIN_DIR")"
SCRIPTS_DIR="$BASE_DIR/scripts"

# Load config
source "$BASE_DIR/lib/load_config.sh"

show_help() {
    echo "================================================================="
    echo "  BioBash: Bioinformatics Analysis Suite"
    echo "================================================================="
    echo "Usage: biobash <category> <script> [args...]"
    echo ""
    echo "Available Categories:"
    for cat in $(find "$SCRIPTS_DIR" -maxdepth 1 -mindepth 1 -type d -exec basename {} \;); do
        echo "  - $cat"
    done
    echo ""
    echo "To list scripts in a category:"
    echo "  biobash <category> --list"
    echo ""
    echo "Generic Options:"
    echo "  --help, -h    Show this help message"
    echo "  --version     Show suite version"
    echo "================================================================="
}

list_category_scripts() {
    local cat=$1
    local cat_dir="$SCRIPTS_DIR/$cat"
    if [[ ! -d "$cat_dir" ]]; then
        echo "Error: Category '$cat' not found."
        exit 1
    fi
    echo "Scripts in category '$cat':"
    for script in $(find "$cat_dir" -name "*.sh" -exec basename {} \;); do
        echo "  - ${script%.sh}"
    done
}

if [[ $# -lt 1 ]]; then
    show_help
    exit 0
fi

# Main logic
case "$1" in
    --help|-h)
        show_help
        ;;
    --version)
        echo "BioBash version 1.0.0"
        ;;
    *)
        CATEGORY=$1
        SCRIPT_NAME=$2
        
        if [[ -z "$SCRIPT_NAME" ]]; then
            show_help
            exit 1
        fi

        if [[ "$SCRIPT_NAME" == "--list" ]]; then
            list_category_scripts "$CATEGORY"
            exit 0
        fi

        # Find the script
        TARGET_SCRIPT="$SCRIPTS_DIR/$CATEGORY/$SCRIPT_NAME.sh"
        if [[ -f "$TARGET_SCRIPT" ]]; then
            shift 2
            bash "$TARGET_SCRIPT" "$@"
        else
            echo "Error: Script '$SCRIPT_NAME' not found in category '$CATEGORY'."
            echo "Use 'biobash $CATEGORY --list' to see available scripts."
            exit 1
        fi
        ;;
esac
